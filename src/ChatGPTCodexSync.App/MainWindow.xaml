<Window x:Class="ChatGPTCodexSync.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="520"
        Width="900"
        MinHeight="460"
        MinWidth="760"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="ChatGPTCodexSync"
                       FontSize="28"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding CodexDirectoryPath}"
                       Margin="0,8,0,0"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,24"
                Padding="18"
                BorderThickness="1"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="16"
                           FontWeight="SemiBold" />

                <TextBox Grid.Row="1"
                         x:Name="LogTextBox"
                         Margin="0,16"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="LogTextBoxTextChanged"
                         Text="{Binding LogText, Mode=OneWay}" />

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ProgressBar Height="8"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressValue, Mode=OneWay}" />
                    <TextBlock Grid.Column="1"
                               MinWidth="52"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               TextAlignment="Right"
                               Text="{Binding ProgressText, Mode=OneWay}" />
                    <ProgressBar Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Height="4"
                                 Margin="0,8,0,0"
                                 IsIndeterminate="{Binding IsBackupRunning, Mode=OneWay}" />
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock Text="7-Zip compression"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <ComboBox Width="120"
                      Margin="0,0,14,0"
                      ItemsSource="{Binding CompressionModes}"
                      SelectedItem="{Binding SelectedCompressionMode}"
                      IsEnabled="{Binding CanConfigureBackup}" />
            <CheckBox Content="Offline mode"
                      VerticalAlignment="Center"
                      Margin="0,0,14,0"
                      IsChecked="{Binding OfflineMode}"
                      IsEnabled="{Binding CanConfigureBackup}" />
            <Button Content="Backup"
                    MinWidth="110"
                    Margin="0,0,10,0"
                    Command="{Binding CreateBackupCommand}" />
            <Button Content="Restore"
                    MinWidth="110"
                    IsEnabled="False" />
        </StackPanel>
    </Grid>
</Window>
